# ── App ────────────────────────────────────────────────────────
# Port exposed on the host (nginx → Angular)
APP_PORT=80

# ── Database (external PostgreSQL) ────────────────────────────
DB_HOST=192.168.1.3
DB_PORT=5432
DB_NAME=invoice_generator
DB_USER=nesticle8bit
DB_PASSWORD=your_postgres_password

# ── JWT ────────────────────────────────────────────────────────
# Use a long random string — generate with:
#   openssl rand -hex 64
JWT_SECRET=change_me_to_a_very_long_random_secret
